{
  "name": "pwsdotru/draw-tides",
  "description": "PHP Library for generate Images by tides points from worldtides client",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Aleksandr Novikov",
      "email": "pwsdotru@gmail.com",
      "homepage": "https://github.com/pwsdotru"
    }
  ],
  "keywords": [
    "worldtides",  "tides", "draw"
  ],
  "require": {
    "php": ">=8.3",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "12.*",
    "squizlabs/php_codesniffer": "3.7.*"
  },
  "autoload": {
    "psr-4": {
      "DrawTides\\": "src/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit -c phpunit.xml",
    "style:check": "vendor/bin/phpcs",
    "style:fix": "vendor/bin/phpcbf",
    "git:prepush": [
      "@style:check",
      "@test"
    ]
  }
}